9 4.86436 10.1003 4.92784 10.0156L11.5738 1.59863C11.6458 1.5013 11.6817 1.40186 11.6817 1.30029C11.6817 1.14372 11.6183 1.01888 11.4913 0.925781L11.1549 0.652832Z" fill="currentcolor"></path></svg></span></div></div></div></div></div><span class=""></span><div class="x10l6tqk xyc4j8s xceh6e4"></div></div><div class="x1c4vz4f xs83m0k xdl72j9 x1g77sc7 x78zum5 xozqiw3 x1oa3qoh x12fk4p8 xeuugli x2lwn1j x13a6bvl x1q0g3np x6s0dn4 _amj_"><div class="x1c4vz4f xs83m0k xdl72j9 x1g77sc7 xeuugli x2lwn1j xozqiw3 x1oa3qoh x12fk4p8 xexx8yu x1im30kd x18d9i69 x1djpfga"><div></div></div></div></div><div class="x78zum5 xbfrwjf x8k05lb xeq5yr9 x1n2onr6 x1f889gz xpvyfi4"></div></div></div></div></div></div></div><div><div tabindex="-1" class="" role="row"><div tabindex="-1" class="_amjv xa0aww2" data-id="3EB08BC040F5721B6B485F"><div class="x78zum5 xdt5ytf" data-virtualized="false" style=""><div class=""><div class="message-out focusable-list-item _amjy _amjw x1klvx2g xahtqtb"><span class=""></span><div class="_amk4 false false _amkd false"><div class="_amk6 _amlo false false"><div><div class="x9f619 x1hx0egp x1yrsyyn xizg8k xu9hqtb xwib8y2"><div class="copyable-text" data-pre-plain-text="[10:19 am, 20/4/2026] Sufiya Khanam: "><div class="_akbu x6ikm8r x10wlt62"><span data-testid="selectable-text" dir="ltr" style="min-height: 0px;" class="x1f6kntn xjb2p0i x8r4c90 xo1l8bm x1ic7a3i x12xpedu _ao3e _aupe copyable-text"><span class="x1lliihq">def _handle_PacketIn(event):
</span><span class="x1lliihq">    packet = event.parsed
</span><span class="x1lliihq">    dpid = event.dpid
</span><span class="x1lliihq">    in_port = event.port
</span><span class="x1lliihq">
</span><span class="x1lliihq">    src = str(packet.src)
</span><span class="x1lliihq">    dst = str(packet.dst)
</span><span class="x1lliihq">
</span><span class="x1lliihq">    mac_to_port[(dpid, src)] = in_port
</span><span class="x1lliihq">
</span><span class="x1lliihq">    flow_id = (src, dst)
</span><span class="x1lliihq">
</span><span class="x1lliihq">    # Initialize path
</span><span class="x1lliihq">    if flow_id not in packet_paths:
</span><span class="x1lliihq">        packet_paths[flow_id] = []
</span><span class="x1lliihq">
</span><span class="x1lliihq">    # Avoid duplicate consecutive switches
</span><span class="x1lliihq">    if not packet_paths[flow_id] or packet_paths[flow_id][-1] != f"s{dpid}":
</span><span class="x1lliihq">        packet_paths[flow_id].append(f"s{dpid}")
</span><span class="x1lliihq">
</span><span class="x1lliihq">    # Forwarding logic
</span><span class="x1lliihq">    if (dpid, dst) in mac_to_port:
</span><span class="x1lliihq">        out_port = mac_to_port[(dpid, dst)]
</span><span class="x1lliihq">    else:
</span><span class="x1lliihq">        out_port = of.OFPP_FLOOD
</span><span class="x1lliihq">
</span><span class="x1lliihq">    msg = of.ofp_flow_mod()
</span><span class="x1lliihq">    msg.match = of.ofp_match.from_packet(packet)
</span><span class="">    msg.actions.append(of.ofp_action_output(port=out_port))…</span></span> <div role="button" tabindex="0" class="xuxw1ft x1ypdohk x1rg5ohu xo1mcw5 x1xlr1w8 x1hl2dhg xt0b8zv xbvygy2 x17f7hit xp30eni xhmieyt read-more-button">Read more</div><span class=""><span class="x3nfvp2 xxymvpz xlshs6z xqtp20y xexx8yu x1uc92m x18d9i69 x181vq82 x12lo8hy x152skdk" aria-hidden="true"><span class="x1c4vz4f x2lah0s xn6xy2s"></span><span class="x1c4vz4f x2lah0s">10:19 am</span></span></span></div></div><div class="x1n2onr6 x1n327nk x18mqm2i xhsvlbd x14z9mp xz62fqu x1wbi8v6"><div class="x1bvqhpb xx3o462 xuxw1ft x78zum5 x6s0dn4 x12lo8hy x152skdk" role="button"><span class="x1rg5ohu x16dsc37" dir="auto"><span class="x193iq5w xeuugli x13faqbe x1vvkbs xt0psk2 x1fj9vlw xhslqc4 x1hx0egp x1pg5gke xjb2p0i xo1l8bm xl2ypbo x1ic7a3i" style="--x-fontSize: 12px; --x-lineHeight: 8.5313px;">10:19 am</span></span><div class="xhslqc4 x1rg5ohu x7phf20"><span aria-hidden="false" aria-label=" Sent " data-icon="msg-check" class=""><svg viewBox="0 0 12 11" height="11" width="16" preserveAspectRatio="xMidYMid meet" class="" fill="none"><title>msg-check</title><path d="M11.1549 0.652832C11.0745 0.585124 10.9729 0.55127 10.8502 0.55127C10.7021 0.55127 10.5751 0.610514 10.4693 0.729004L4.28038 8.36523L1.87461 6.09277C1.8323 6.04622 1.78151 6.01025 1.72227 5.98486C1.66303 5.95947 1.60166 5.94678 1.53819 5.94678C1.407 5.94678 1.29275 5.99544 1.19541 6.09277L0.884379 6.40381C0.79128 6.49268 0.744731 6.60482 0.744731 6.74023C0.744731 6.87565 0.79128 6.98991 0.884379 7.08301L3.88047 10.0791C4.02859 10.2145 4.19574 10.2822 4.38194 10.2822C4.48773 10.2822 4.58929 10.259 4.68663 10.2124C4.78396 10.1659 4.86436 10.1003 4.92784 10.0156L11.5738 1.59863C11.6458 1.5013 11.6817 1.40186 11.6817 1.30029C11.6817 1.14372 11.6183 1.01888 11.4913 0.925781L11.1549 0.652832Z" fill="currentcolor"></path></svg></span></div></div></div></div></div><span class=""></span><div class="x10l6tqk xyc4j8s xceh6e4"></div></div><div class="x1c4vz4f xs83m0k xdl72j9 x1g77sc7 x78zum5 xozqiw3 x1oa3qoh x12fk4p8 xeuugli x2lwn1j x13a6bvl x1q0g3np x6s0dn4 _amj_"><div class="x1c4vz4f xs83m0k xdl72j9 x1g77sc7 xeuugli x2lwn1j xozqiw3 x1oa3qoh x12fk4p8 xexx8yu x1im30kd x18d9i69 x1djpfga"><div></div></div></div></div><div class="x78zum5 xbfrwjf x8k05lb xeq5yr9 x1n2onr6 x1f889gz xpvyfi4"></div></div></div></div></div></div></div><div><div tabindex="-1" class="" role="row"><div tabindex="-1" class="_amjv xa0aww2" data-id="3EB0548FDF136D522C0B62"><div class="x78zum5 xdt5ytf" data-virtualized="false" style=""><div class=""><div class="message-out focusable-list-item _amjy _amjw x1klvx2g xahtqtb"><span class=""></span><div class="_amk4 false false _amkd false"><div class="_amk6 _amlo false false"><div><div class="x9f619 x1hx0egp x1yrsyyn xizg8k xu9hqtb xwib8y2"><div class="copyable-text" data-pre-plain-text="[10:20 am, 20/4/2026] Sufiya Khanam: "><div class="_akbu x6ikm8r x10wlt62"><span data-testid="selectable-text" dir="ltr" style="min-height: 0px;" class="x1f6kntn xjb2p0i x8r4c90 xo1l8bm x1ic7a3i x12xpedu _ao3e _aupe copyable-text"><span class="x1lliihq">def mac_to_host(mac):
</span><span class="x1lliihq">    mac = str(mac)
</span><span class="x1lliihq">    if mac.endswith("01"):
</span><span class="x1lliihq">        return "h1"
</span><span class="x1lliihq">    elif mac.endswith("02"):
</span><span class="x1lliihq">        return "h2"
</span><span class="">    return mac</span></span><span class=""><span class="x3nfvp2 xxymvpz xlshs6z xqtp20y xexx8yu x1uc92m x18d9i69 x181vq82 x12lo8hy x152skdk" aria-hidden="true"><span class="x1c4vz4f x2lah0s xn6xy2s"></span><span class="x1c4vz4f x2lah0s">10:20 am</span></span></span></div></div><div class="x1n2onr6 x1n327nk x18mqm2i xhsvlbd x14z9mp xz62fqu x1wbi8v6"><div class="x1bvqhpb xx3o462 xuxw1ft x78zum5 x6s0dn4 x12lo8hy x152skdk" role="button"><span class="x1rg5ohu x16dsc37" dir="auto"><span class="x193iq5w xeuugli x13faqbe x1vvkbs xt0psk2 x1fj9vlw xhslqc4 x1hx0egp x1pg5gke xjb2p0i xo1l8bm xl2ypbo x1ic7a3i" style="--x-fontSize: 12px; --x-lineHeight: 8.5313px;">10:20 am</span></span><div class="xhslqc4 x1rg5ohu x7phf20"><span aria-hidden="false" aria-label=" Sent " data-icon="msg-check" class=""><svg viewBox="0 0 12 11" height="11" width="16" preserveAspectRatio="xMidYMid meet" class="" fill="none"><title>msg-check</title><path d="M11.1549 0.652832C11.0745 0.585124 10.9729 0.55127 10.8502 0.55127C10.7021 0.55127 10.5751 0.610514 10.4693 0.729004L4.28038 8.36523L1.87461 6.09277C1.8323 6.04622 1.78151 6.01025 1.72227 5.98486C1.66303 5.95947 1.60166 5.94678 1.53819 5.94678C1.407 5.94678 1.29275 5.99544 1.19541 6.09277L0.884379 6.40381C0.79128 6.49268 0.744731 6.60482 0.744731 6.74023C0.744731 6.87565 0.79128 6.98991 0.884379 7.08301L3.88047 10.0791C4.02859 10.2145 4.19574 10.2822 4.38194 10.2822C4.48773 10.2822 4.58929 10.259 4.68663 10.2124C4.78396 10.1659 4.86436 10.1003 4.92784 10.0156L11.5738 1.59863C11.6458 1.5013 11.6817 1.40186 11.6817 1.30029C11.6817 1.14372 11.6183 1.01888 11.4913 0.925781L11.1549 0.652832Z" fill="currentcolor"></path></svg></span></div></div></div></div></div><span class=""></span><div class="x10l6tqk xyc4j8s xceh6e4"></div></div><div class="x1c4vz4f xs83m0k xdl72j9 x1g77sc7 x78zum5 xozqiw3 x1oa3qoh x12fk4p8 xeuugli x2lwn1j x13a6bvl x1q0g3np x6s0dn4 _amj_"><div class="x1c4vz4f xs83m0k xdl72j9 x1g77sc7 xeuugli x2lwn1j xozqiw3 x1oa3qo